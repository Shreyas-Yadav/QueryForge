# QueryForge configuration — copy to .env and fill in. Never commit .env.

# --- Model provider ---
# Which model backs the agent: 'gemini' or 'claude'.
PROVIDER=gemini
# Pick a model your API key can use. 'gemini-flash-latest' is a rolling alias to
# the current flash model (safe default); older ids like 'gemini-2.5-flash' are
# retired for new API-key users. List yours: check https://aistudio.google.com.
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Gemini via API key (no GCP needed) ---
# Easiest way to run: get a free key at https://aistudio.google.com/apikey and
# paste it here. When GEMINI_API_KEY is set, the Gemini provider uses Google AI
# Studio directly — no GCP project, no gcloud, no Vertex/ADC. Leave PROVIDER=gemini.
GEMINI_API_KEY=

# --- Vertex AI (alternative to the API key above) ---
# Only needed when GEMINI_API_KEY is empty (or PROVIDER=claude, which runs on
# Vertex). Auth is via Application Default Credentials, so run once:
#   gcloud auth application-default login
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-east5
# Claude model (used when PROVIDER=claude). Bare id, no 'anthropic.' prefix.
MODEL=claude-sonnet-4-6

# --- Which database to query ---
# 'cloud' = Oracle Autonomous Database over an mTLS wallet.
# 'local' = Oracle in Docker or installed on this machine.
# Both blocks below can stay filled in; flip this one line to switch. The driver
# runs in thin mode either way, so no Instant Client on any OS.
DB_TARGET=cloud

# --- cloud: Oracle Autonomous Database (mTLS wallet) ---
# The real security boundary is a read-only user (GRANT CREATE SESSION + SELECT
# only). To share one DB across machines, send these values + the wallet folder
# out-of-band (never commit them); the recipient points the paths below at their
# own copy of the wallet.
CLOUD_ORACLE_USER=qf_readonly
CLOUD_ORACLE_PASSWORD=change-me
# TNS alias from tnsnames.ora inside the wallet (…_low / _medium / _high / _tp).
CLOUD_ORACLE_DSN=mydb_low
# Schema the agent reads. Set this when the user above is a read-only user whose
# granted tables live in another schema (e.g. the owning schema). If the read-only
# user and the data are in the same schema, leave blank.
CLOUD_ORACLE_SCHEMA=
# Point these at the unzipped wallet directory. Leave all three blank if your ADB
# uses one-way TLS — then put the full connect descriptor in CLOUD_ORACLE_DSN.
CLOUD_ORACLE_CONFIG_DIR=/absolute/path/to/wallet
CLOUD_ORACLE_WALLET_LOCATION=/absolute/path/to/wallet
CLOUD_ORACLE_WALLET_PASSWORD=your-wallet-pem-password

# --- local: Oracle in Docker or installed natively (no wallet) ---
# See the "Local Oracle" section in the README for how to start one per OS.
# 'system' gets a fresh container connected, but it sees ~45 Oracle system tables
# that pad the agent's schema overview — and it is not read-only. Once your data is
# loaded, create the read-only user from the Prerequisites step here instead.
LOCAL_ORACLE_USER=system
LOCAL_ORACLE_PASSWORD=oracle
# host:port/service — FREEPDB1 for 23ai Free, XEPDB1 for XE 21c.
LOCAL_ORACLE_DSN=localhost:1521/FREEPDB1
LOCAL_ORACLE_SCHEMA=

# Unprefixed ORACLE_* variables still work as fallbacks for the cloud target, so
# an older .env written before DB_TARGET existed keeps connecting unchanged.

# --- Query guardrails ---
MAX_ROWS=200
QUERY_TIMEOUT_S=30
